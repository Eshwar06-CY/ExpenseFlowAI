# ============================================================
# ExpenseFlowAI - Environment Configuration Example
# Copy this file to ".env" and replace the placeholder values.
# Never commit your real .env file.
# ============================================================

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
APP_NAME=ExpenseFlowAI
APP_ENV=development
DEBUG=true
API_V1_STR=/api/v1
LOG_LEVEL=INFO

# ------------------------------------------------------------
# Database (Development)
# ------------------------------------------------------------
# SQLite (Recommended for local development)
DATABASE_URL=sqlite:///./dev.db

# Example PostgreSQL (Production)
# DATABASE_URL=postgresql://username:password@localhost:5432/expenseflowai

# ------------------------------------------------------------
# Security
# ------------------------------------------------------------
# Generate using:
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace_with_secure_random_secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# ------------------------------------------------------------
# Frontend
# ------------------------------------------------------------
FRONTEND_URL=http://localhost:5173

# ------------------------------------------------------------
# Email Configuration (SMTP)
# ------------------------------------------------------------
SMTP_SERVER=your_smtp_server
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_USE_TLS=true

MAIL_FROM_EMAIL=your_email@example.com
MAIL_FROM_NAME=ExpenseFlowAI

# ------------------------------------------------------------
# AI Configuration (Google Gemini 2.5 Flash)
# ------------------------------------------------------------
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.6-flash
GEMINI_TIMEOUT=60.0
GEMINI_TEMPERATURE=0.3
GEMINI_TOP_P=0.9
GEMINI_TOP_K=40
GEMINI_MAX_OUTPUT_TOKENS=1024

# ------------------------------------------------------------
# CORS
# ------------------------------------------------------------
BACKEND_CORS_ORIGINS=http://localhost:5173

# ------------------------------------------------------------
# File Uploads
# ------------------------------------------------------------
MAX_UPLOAD_SIZE_MB=10

# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------
ENABLE_REQUEST_LOGGING=true

# ------------------------------------------------------------
# Cache (Optional)
# ------------------------------------------------------------
# CACHE_PROVIDER=memory
# REDIS_URL=redis://localhost:6379/0

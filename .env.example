# ExpenseFlow AI Environment Variables Template

# App Settings
PROJECT_NAME=ExpenseFlow AI
API_V1_STR=/api/v1
LOG_LEVEL=INFO

# Security (Change JWT_SECRET for production!)
JWT_SECRET=super_secret_key_change_me_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost,http://localhost:80

# Password reset and outbound SMTP email (optional in development)
FRONTEND_URL=http://localhost:5173
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
EMAILS_FROM_EMAIL=your_email@gmail.com
EMAILS_FROM_NAME=ExpenseFlow AI

# Database Configuration
MYSQL_DATABASE=expenseflow
MYSQL_ROOT_PASSWORD=root_password_here
MYSQL_USER=expenseflow_user
MYSQL_PASSWORD=user_password_here

# AI Financial Advisor Configuration (Ollama Local LLM)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_TIMEOUT=60.0

# Frontend API URL
VITE_API_URL=http://localhost:8000/api/v1

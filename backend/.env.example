# Project Configuration
PROJECT_NAME="ExpenseFlow AI"
API_V1_STR="/api/v1"
LOG_LEVEL="INFO"

# Database Configuration (MySQL)
# Format: mysql+pymysql://user:password@host:port/dbname
DATABASE_URL="mysql+pymysql://expenseflow_user:user_password_here@localhost:3306/expenseflow"

# Security Configuration
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET="your_fallback_super_secret_signing_key_for_jwt_tokens_here"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Password reset and outbound SMTP email (Brevo / Generic SMTP)
FRONTEND_URL=http://localhost:5173
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60
BREVO_SMTP_SERVER=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USERNAME="your_brevo_smtp_username"
BREVO_SMTP_PASSWORD="your_brevo_smtp_password"
MAIL_FROM="noreply@expenseflow.ai"

# AI Financial Advisor Configuration (Ollama Local LLM)
LLM_PROVIDER="ollama"
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="qwen3:8b"
OLLAMA_TIMEOUT=60.0
EMAILS_FROM_NAME=ExpenseFlow AI
